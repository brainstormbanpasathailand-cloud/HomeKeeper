# -------- Core --------
ENV=development
DATABASE_URL=postgresql://homekeeper:homekeeper@localhost:5432/homekeeper
# For quick local start without Postgres you may use:
# DATABASE_URL=sqlite:///./homekeeper.db

# -------- JWT / Sessions --------
JWT_SECRET=please-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# -------- URLs --------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -------- Cookies --------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# -------- Seed super admin (used only by scripts/seed.py) --------
SEED_ADMIN_EMAIL=admin@homekeeper.local
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=HomeKeeper Admin

# -------- OAuth: LINE Login --------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=http://localhost:5173/auth/callback/line

# -------- OAuth: Google --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/callback/google

# -------- OAuth: Facebook --------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5173/auth/callback/facebook

# -------- Storage (Cloudinary or S3-compatible) --------
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=
STORAGE_ENDPOINT=
CLOUDINARY_URL=

# -------- Email --------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@homekeeper.local

# -------- Rate limiting --------
RATE_LIMIT_AUTH=10/minute
